{
    "metadata": {
        "id": "iso19650-core-system",
        "name": "Core Information System",
        "description": "Core information management concepts and relationships defined in ISO 19650:2018, including the information standard and lifecycle integration.",
        "type": "concept-map",
        "standard": "ISO 19650",
        "version": "2018",
        "part": "Part 1 / Part 2",
        "created": "2026-03-14",
        "author": "ISO19650 Knowledge Maps",
        "tags": [ "core", "information-management", "architecture", "standard" ]
    },

    "graph": {

        "nodes": [

            {
                "id": "Asset",
                "label": "Asset",
                "type": "concept",
                "description": "Built asset or infrastructure whose lifecycle is supported by information."
            },

            {
                "id": "Lifecycle",
                "label": "Asset Lifecycle",
                "type": "concept",
                "description": "Lifecycle stages of an asset including delivery phase and operational phase."
            },

            {
                "id": "Decision",
                "label": "Decision",
                "type": "concept",
                "description": "Decision made during the lifecycle of an asset at key decision points."
            },

            {
                "id": "InformationRequirement",
                "label": "Information Requirement",
                "type": "information",
                "description": "Specification of what, when, how and for whom information is to be produced."
            },

            {
                "id": "InformationStandard",
                "label": "Information Standard",
                "type": "concept",
                "description": "Specification for structuring and classifying information, including naming conventions, attributes, and formats."
            },

            {
                "id": "LevelOfInformationNeed",
                "label": "Level of Information Need",
                "type": "concept",
                "description": "Framework which defines the extent and granularity of information to prevent delivery of too much information."
            },

            {
                "id": "InformationProduction",
                "label": "Information Production",
                "type": "process",
                "description": "Activity of creating information during project delivery or asset operation."
            },

            {
                "id": "InformationVerification",
                "label": "Information Verification",
                "type": "process",
                "description": "Checking and validating information before exchange, including quality assurance and review."
            },

            {
                "id": "InformationExchange",
                "label": "Information Exchange",
                "type": "process",
                "description": "Act of satisfying an information requirement through delivery of information containers."
            },

            {
                "id": "InformationContainer",
                "label": "Information Container",
                "type": "information",
                "description": "Named persistent set of information retrievable from within a file, system or application storage hierarchy."
            },

            {
                "id": "InformationModel",
                "label": "Information Model",
                "type": "information",
                "description": "Set of structured and unstructured information containers."
            },

            {
                "id": "ProjectInformationModel",
                "label": "Project Information Model (PIM)",
                "type": "information",
                "description": "Information model relating to the delivery phase."
            },

            {
                "id": "AssetInformationModel",
                "label": "Asset Information Model (AIM)",
                "type": "information",
                "description": "Information model relating to the operational phase."
            },

            {
                "id": "CDE",
                "label": "Common Data Environment",
                "type": "system",
                "description": "Agreed source of information for collecting, managing and disseminating information containers through a managed process."
            },

            {
                "id": "InformationProducer",
                "label": "Information Producer",
                "type": "role",
                "description": "Party responsible for producing information to meet requirements."
            }

        ],

