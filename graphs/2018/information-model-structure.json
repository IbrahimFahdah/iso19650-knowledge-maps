        "tags": [ "information-model", "PIM", "AIM", "structure", "hierarchy", "container" ]
    },

    "graph": {

        "nodes": [

            {
                "id": "InformationContainer",
                "label": "Information Container",
                "type": "information",
                "description": "Named persistent set of information retrievable from within a file, system or application storage hierarchy."
            },

            {
                "id": "InformationModel",
                "label": "Information Model",
                "type": "information",
                "description": "Set of structured and unstructured information containers."
            },

            {
                "id": "FederatedInformationModel",
                "label": "Federated Information Model",
                "type": "information",
                "description": "Composite information model created from separate information containers originating from different task teams."
            },

            {
                "id": "ProjectInformationModel",
                "label": "Project Information Model (PIM)",
                "type": "information",
                "description": "Information model relating to the delivery phase."
            },

            {
                "id": "AssetInformationModel",
                "label": "Asset Information Model (AIM)",
                "type": "information",
                "description": "Information model relating to the operational phase."
            },

            {
                "id": "TaskTeam",
                "label": "Task Team",
                "type": "role",
                "description": "Individuals assembled to perform a specific task responsible for producing information containers."
            },

            {
                "id": "DeliveryTeam",
                "label": "Delivery Team",
                "type": "role",
                "description": "Lead appointed party and appointed parties responsible for producing project information."
            },

            {
                "id": "FederationStrategy",
                "label": "Federation Strategy",
                "type": "concept",
                "description": "Approach describing how the information model is divided into sets of information containers allowing task teams to work simultaneously."
            },

            {
                "id": "InformationContainerBreakdownStructure",
                "label": "Information Container Breakdown Structure",
                "type": "concept",
                "description": "Structure defining how information containers relate to each other during detailed planning."
            },

            {
                "id": "CDE",
                "label": "Common Data Environment",
                "type": "system",
                "description": "Agreed source of information for collecting, managing and disseminating each information container."
            }

