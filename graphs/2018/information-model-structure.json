        "id": "iso19650-information-model-structure",
        "name": "Information Model Structure",
        "description": "Hierarchy of information containers and information models defined in ISO 19650:2018, showing how containers form models and the relationship between PIM and AIM.",
        "type": "structure-map",
        "standard": "ISO 19650",
        "version": "2018",
        "part": "Part 1",
