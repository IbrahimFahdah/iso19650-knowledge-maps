{
    "metadata": {
        "id": "iso19650-cde-workflow",
        "name": "CDE Workflow",
        "description": "Information container states and transitions within the Common Data Environment as defined in ISO 19650-1 Clause 12.",
        "type": "process-map",
        "standard": "ISO 19650",
        "version": "2018",
        "part": "Part 1",
        "created": "2026-03-14",
        "author": "ISO19650 Knowledge Maps",
        "tags": [ "CDE", "workflow", "information-state", "container" ]
    },

    "graph": {

        "nodes": [

            {
                "id": "InformationContainer",
                "label": "Information Container",
                "type": "information",
                "description": "Named persistent set of information retrievable from within a file, system or application storage hierarchy."
            },

            {
                "id": "WorkInProgress",
                "label": "Work In Progress",
                "type": "state",
                "description": "State where information is being developed by its originating task team and is not visible or accessible to other teams."
            },

            {
                "id": "Shared",
                "label": "Shared",
                "type": "state",
                "description": "State where information is shared with other teams for coordination and collaborative development."
            },

            {
                "id": "Published",
                "label": "Published",
                "type": "state",
                "description": "State where information has been authorized for use in subsequent stages, construction, or asset operation."
            },

            {
                "id": "Archived",
                "label": "Archived",
                "type": "state",
                "description": "State providing a journal of all information container transactions and an audit trail of their development."
            },

            {
                "id": "CheckReviewApprove",
                "label": "Check / Review / Approve",
                "type": "process",
                "description": "Transition process where the originating task team checks, reviews and approves information before sharing."
            },

            {
                "id": "ReviewAuthorize",
                "label": "Review / Authorize",
                "type": "process",
                "description": "Transition process where information is reviewed against requirements and authorized for use."
            },

            {
                "id": "InformationExchange",
                "label": "Information Exchange",
                "type": "process",
                "description": "Event where information containers are delivered to satisfy information requirements."
            },

            {
                "id": "CDE",
                "label": "Common Data Environment",
                "type": "system",
                "description": "Agreed source of information for collecting, managing and disseminating each information container through a managed process."
            },

            {
                "id": "TaskTeam",
                "label": "Task Team",
                "type": "role",
                "description": "Individuals assembled to perform a specific task, responsible for developing and reviewing information."
            },

            {
                "id": "LeadAppointedParty",
                "label": "Lead Appointed Party",
                "type": "role",
                "description": "Organization responsible for coordinating the delivery team and authorizing information before publication."
            },

            {
                "id": "AppointingParty",
                "label": "Appointing Party",
                "type": "role",
                "description": "The party receiving information and responsible for reviewing and accepting information exchanges."
            }

        ],

        "edges": [

            {
                "id": "e1",
                "source": "InformationContainer",
                "target": "WorkInProgress",
                "relationship": "created_in",
                "label": "created in",
                "evidence": {
                    "quote": "Information containers are developed within the work in progress state of the common data environment.",
                    "source": "ISO 19650-1",
                    "type": "definition"
                }
            },

            {
                "id": "e2",
                "source": "TaskTeam",
                "target": "WorkInProgress",
                "relationship": "develops",
                "label": "develops",
                "evidence": {
                    "quote": "The work in progress state is used for information while it is being developed by its task team.",
                    "source": "ISO 19650-1:2018, 12.2",
                    "type": "definition"
                }
            },

            {
                "id": "e3",
                "source": "TaskTeam",
                "target": "CheckReviewApprove",
                "relationship": "performs",
                "label": "performs",
                "evidence": {
                    "quote": "The check/review/approve transition should be made by the originating task team.",
                    "source": "ISO 19650-1:2018, 12.3",
                    "type": "definition"
                }
            },

            {
                "id": "e4",
                "source": "WorkInProgress",
                "target": "CheckReviewApprove",
                "relationship": "submitted_for",
                "label": "submitted for",
                "evidence": {
                    "quote": "Information containers are checked, reviewed and approved before being shared.",
                    "source": "ISO 19650-1:2018, 12.3",
                    "type": "definition"
                }
            },

            {
                "id": "e5",
                "source": "CheckReviewApprove",
                "target": "Shared",
                "relationship": "transitions_to",
                "label": "transitions to",
                "evidence": {
                    "quote": "Information is shared for coordination once it has been checked, reviewed and approved for sharing.",
                    "source": "ISO 19650-1:2018, 12.4",
                    "type": "definition"
                }
            },

            {
                "id": "e6",
                "source": "Shared",
                "target": "ReviewAuthorize",
                "relationship": "submitted_for",
                "label": "submitted for",
                "evidence": {
                    "quote": "The review/authorize transition compares information containers at information exchange against the relevant information requirements.",
                    "source": "ISO 19650-1:2018, 12.5",
                    "type": "definition"
                }
            },

            {
                "id": "e7",
                "source": "LeadAppointedParty",
                "target": "ReviewAuthorize",
                "relationship": "performs",
                "label": "performs",
                "evidence": {
                    "quote": "Information containers are reviewed and authorized prior to being published.",
                    "source": "ISO 19650-1:2018, 12.5",
                    "type": "definition"
                }
            },

            {
                "id": "e8",
                "source": "AppointingParty",
                "target": "ReviewAuthorize",
                "relationship": "may_perform",
                "label": "may perform",
                "evidence": {
                    "quote": "The appointing party reviews and accepts information models at information exchanges.",
                    "source": "ISO 19650-2",
                    "type": "definition"
                }
            },

            {
                "id": "e9",
                "source": "ReviewAuthorize",
                "target": "Published",
                "relationship": "transitions_to",
                "label": "transitions to",
                "evidence": {
                    "quote": "If an information container meets the information requirements, its state is changed to published.",
                    "source": "ISO 19650-1:2018, 12.5",
                    "type": "definition"
                }
            },

            {
                "id": "e10",
                "source": "Published",
                "target": "Archived",
                "relationship": "transitions_to",
                "label": "transitions to",
                "evidence": {
                    "quote": "The archive state is used to hold a journal of all information containers that have been shared and published.",
                    "source": "ISO 19650-1:2018, 12.7",
                    "type": "definition"
                }
            },

            {
                "id": "e11",
                "source": "Shared",
                "target": "WorkInProgress",
                "relationship": "can_return_to",
                "label": "can return to",
                "evidence": {
                    "quote": "If editing is required, an information container should be returned to the work in progress state.",
                    "source": "ISO 19650-1:2018, 12.4",
                    "type": "definition"
                }
            },

            {
                "id": "e12",
                "source": "InformationExchange",
                "target": "ReviewAuthorize",
                "relationship": "occurs_during",
                "label": "occurs during",
                "evidence": {
                    "quote": "The review/authorize transition compares information containers at information exchange.",
                    "source": "ISO 19650-1:2018, 12.5",
                    "type": "definition"
                }
            },

            {
                "id": "e13",
                "source": "CDE",
                "target": "WorkInProgress",
                "relationship": "contains",
                "label": "contains",
                "evidence": {
                    "quote": "The common data environment is the agreed source of information for the project.",
                    "source": "ISO 19650-1:2018",
                    "type": "definition"
                }
            },

            {
                "id": "e14",
                "source": "CDE",
                "target": "Shared",
                "relationship": "contains",
                "label": "contains",
                "evidence": {
                    "quote": "The common data environment manages information through defined states.",
                    "source": "ISO 19650-1:2018",
                    "type": "definition"
                }
            },

            {
                "id": "e15",
                "source": "CDE",
                "target": "Published",
                "relationship": "contains",
                "label": "contains",
                "evidence": {
                    "quote": "Authorized information is made available through the common data environment.",
                    "source": "ISO 19650-1:2018",
                    "type": "definition"
                }
            },

            {
                "id": "e16",
                "source": "CDE",
                "target": "Archived",
                "relationship": "contains",
                "label": "contains",
                "evidence": {
                    "quote": "The archive state provides a journal of information container transactions.",
                    "source": "ISO 19650-1:2018",
                    "type": "definition"
                }
            }

        ]
    }
}