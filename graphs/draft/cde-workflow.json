{
    "metadata": {
        "id": "iso19650-cde-workflow-v4",
        "name": "CDE Workflow and Information Production",
        "description": "Comprehensive representation of information container states, transitions, coordination processes, roles, and exchanges within the Common Data Environment according to ISO 19650:2026 draft.",
        "type": "process-map",
        "standard": "ISO 19650",
        "version": "2026-draft",
        "part": "Part 1 / Part 2",
        "created": "2026-03-14",
        "author": "ISO19650 Knowledge Maps",
        "tags": [ "CDE", "workflow", "information-state", "container", "information-production", "information-exchange" ]
    },

    "graph": {

        "nodes": [

            {
                "id": "InformationContainer",
                "label": "Information Container",
                "type": "information",
                "description": "Named persistent set of information retrievable from within a file, system or application storage hierarchy."
            },

            {
                "id": "InformationModel",
                "label": "Information Model",
                "type": "information",
                "description": "Structured aggregation of multiple information containers forming the project information model or asset information model."
            },

            {
                "id": "InformationPurpose",
                "label": "Information Purpose",
                "type": "concept",
                "description": "Reason why information is produced and used, such as coordination, approval, construction, or asset operation."
            },

            {
                "id": "InformationProductionRequirements",
                "label": "Information Production Requirements",
                "type": "requirement",
                "description": "Requirements defining what information must be produced, when it must be delivered, and for what purpose."
            },

            {
                "id": "WorkInProgress",
                "label": "WORK IN PROGRESS",
                "type": "state",
                "description": "State where information is being developed by its authoring appointed party and is not visible to other parties. This is the only state where information can be generated or amended."
            },

            {
                "id": "Shared",
                "label": "SHARED",
                "type": "state",
                "description": "State where information is shared with other parties within the information production team for coordination and collaborative development."
            },

            {
                "id": "Published",
                "label": "PUBLISHED",
                "type": "state",
                "description": "State where information has been authorized by the lead appointed party and accepted by the appointing party for use."
            },

            {
                "id": "Archived",
                "label": "ARCHIVED",
                "type": "state",
                "description": "State where superseded information containers are retained for audit, historical reference, or legal purposes."
            },

            {
                "id": "CheckReviewApprove",
                "label": "Check / Review / Approve",
                "type": "process",
                "description": "Process where the appointed party verifies the information container against the information production standard before sharing."
            },

            {
                "id": "CoordinationReview",
                "label": "Coordination Review",
                "type": "process",
                "description": "Process where appointed parties coordinate shared information containers to resolve inconsistencies and ensure alignment."
            },

            {
                "id": "InformationExchange",
                "label": "Information Exchange",
                "type": "process",
                "description": "Planned event where an information model is delivered to satisfy defined information production requirements."
            },

            {
                "id": "ReviewAuthorize",
                "label": "Review / Authorize",
                "type": "process",
                "description": "Process where the lead appointed party reviews the information model against information production requirements and authorizes it for submission."
            },

            {
                "id": "ReviewAccept",
                "label": "Review / Accept",
                "type": "process",
                "description": "Process where the appointing party reviews the submitted information model and accepts it for use."
            },

            {
                "id": "StatusCode",
                "label": "Status Code",
                "type": "information",
                "description": "Property signifying the permitted use of an information container’s content based on its workflow state and approved purpose."
            },

            {
                "id": "CDE",
                "label": "Common Data Environment",
                "type": "system",
                "description": "Operational framework combining the information production workflow and enabling technologies to facilitate collaborative information production."
            },

            {
                "id": "AppointedParty",
                "label": "Appointed Party",
                "type": "role",
                "description": "Party responsible for generating and coordinating information containers."
            },

            {
                "id": "LeadAppointedParty",
                "label": "Lead Appointed Party",
                "type": "role",
                "description": "Party responsible for managing information production and authorizing information models."
            },

            {
                "id": "AppointingParty",
                "label": "Appointing Party",
                "type": "role",
                "description": "Party accountable for defining information requirements and accepting delivered information."
            }

        ],

