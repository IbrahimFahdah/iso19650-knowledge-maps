{
    "metadata": {
        "id": "iso19650-cde-workflow",
        "name": "CDE Workflow",
        "description": "Information container states and transitions within the Common Data Environment according to ISO 19650 information management principles.",
        "type": "process-map",
        "standard": "ISO 19650",
        "version": "Draft 2026",
        "part": "Part 1 / Part 2",
        "created": "2026-03-14",
        "author": "ISO19650 Knowledge Maps",
        "tags": [ "CDE", "workflow", "information-state", "container" ]
    },

    "graph": {

        "nodes": [

            {
                "id": "InformationContainer",
                "label": "Information Container",
                "type": "information",
                "description": "Named persistent set of information retrievable from within a file, system or application storage hierarchy."
            },

            {
                "id": "WorkInProgress",
                "label": "Work In Progress",
                "type": "state",
                "description": "State where information is being developed by its originating task team and is not visible or accessible to other teams."
            },

            {
                "id": "Shared",
                "label": "Shared",
                "type": "state",
                "description": "State where information is shared with other teams for coordination and collaborative development."
            },

            {
                "id": "Published",
                "label": "Published",
                "type": "state",
                "description": "State where information has been authorized for use for delivery, construction, or asset operation."
            },

            {
                "id": "Archived",
                "label": "Archived",
                "type": "state",
                "description": "State providing a record of all information container transactions and an audit trail of their development."
            },

            {
                "id": "CheckReviewApprove",
                "label": "Check / Review / Approve",
                "type": "process",
                "description": "Process where the originating task team verifies the information container before it becomes available for sharing."
            },

            {
                "id": "ReviewAuthorize",
                "label": "Review / Authorize",
                "type": "process",
                "description": "Process where information is reviewed against requirements and authorized for use at information exchanges."
            },

            {
                "id": "InformationExchange",
                "label": "Information Exchange",
                "type": "process",
                "description": "Event where information containers are delivered to satisfy defined information requirements."
            },

            {
                "id": "CDE",
                "label": "Common Data Environment",
                "type": "system",
                "description": "Agreed source of information for collecting, managing and disseminating each information container through a managed process."
            },

            {
                "id": "TaskTeam",
                "label": "Task Team",
                "type": "role",
                "description": "Individuals assembled to perform a specific task and responsible for developing project information."
            },

            {
                "id": "LeadAppointedParty",
                "label": "Lead Appointed Party",
                "type": "role",
                "description": "Organization responsible for coordinating information delivery and authorizing information before publication."
            },

            {
                "id": "AppointingParty",
                "label": "Appointing Party",
                "type": "role",
                "description": "Organization that defines information requirements and receives information deliverables."
            }

        ],

        "edges": [

            {
                "id": "e1",
                "source": "InformationContainer",
                "target": "WorkInProgress",
                "relationship": "created_in",
                "label": "created in",
                "evidence": {
                    "quote": "Information containers are developed within the work in progress state before being shared.",
                    "source": "ISO 19650-1",
                    "type": "definition"
                }
            },

            {
                "id": "e2",
                "source": "TaskTeam",
                "target": "WorkInProgress",
                "relationship": "develops",
                "label": "develops",
                "evidence": {
                    "quote": "The work in progress state is used while information is being developed by the task team.",
                    "source": "ISO 19650-1",
                    "type": "definition"
                }
            },

            {
                "id": "e3",
                "source": "TaskTeam",
                "target": "CheckReviewApprove",
                "relationship": "performs",
                "label": "performs",
                "evidence": {
                    "quote": "Information should be checked and reviewed by the originating task team before sharing.",
                    "source": "ISO 19650-1",
                    "type": "definition"
                }
            },

            {
                "id": "e4",
                "source": "WorkInProgress",
                "target": "CheckReviewApprove",
                "relationship": "submitted_for",
                "label": "submitted for",
                "evidence": {
                    "quote": "Information containers are verified before being shared for coordination.",
                    "source": "ISO 19650-1",
                    "type": "definition"
                }
            },

            {
                "id": "e5",
                "source": "CheckReviewApprove",
                "target": "Shared",
                "relationship": "transitions_to",
                "label": "transitions to",
                "evidence": {
                    "quote": "Information is shared with other parties once it has been checked and approved for sharing.",
                    "source": "ISO 19650-1",
                    "type": "definition"
                }
            },

            {
                "id": "e6",
                "source": "Shared",
                "target": "ReviewAuthorize",
                "relationship": "submitted_for",
                "label": "submitted for",
                "evidence": {
                    "quote": "Information containers are reviewed against information requirements at information exchanges.",
                    "source": "ISO 19650-2",
                    "type": "definition"
                }
            },

            {
                "id": "e7",
                "source": "LeadAppointedParty",
                "target": "ReviewAuthorize",
                "relationship": "performs",
                "label": "performs",
                "evidence": {
                    "quote": "The lead appointed party coordinates and authorizes information before publication.",
                    "source": "ISO 19650-2",
                    "type": "definition"
                }
            },

            {
                "id": "e8",
                "source": "AppointingParty",
                "target": "ReviewAuthorize",
                "relationship": "may_perform",
                "label": "may perform",
                "evidence": {
                    "quote": "The appointing party receives and reviews information delivered at exchanges.",
                    "source": "ISO 19650-2",
                    "type": "definition"
                }
            },

            {
                "id": "e9",
                "source": "ReviewAuthorize",
                "target": "Published",
                "relationship": "transitions_to",
                "label": "transitions to",
                "evidence": {
                    "quote": "If information satisfies the requirements it becomes authorized for use.",
                    "source": "ISO 19650-2",
                    "type": "definition"
                }
            },

            {
                "id": "e10",
                "source": "Published",
                "target": "Archived",
                "relationship": "transitions_to",
                "label": "transitions to",
                "evidence": {
                    "quote": "The archive state maintains a record of information container history.",
                    "source": "ISO 19650-1",
                    "type": "definition"
                }
            },

            {
                "id": "e11",
                "source": "Shared",
                "target": "WorkInProgress",
                "relationship": "can_return_to",
                "label": "can return to",
                "evidence": {
                    "quote": "Information containers may return to work in progress if revisions are required.",
                    "source": "ISO 19650-1",
                    "type": "definition"
                }
            },

            {
                "id": "e12",
                "source": "InformationExchange",
                "target": "ReviewAuthorize",
                "relationship": "occurs_during",
                "label": "occurs during",
                "evidence": {
                    "quote": "Information exchanges compare delivered information with defined requirements.",
                    "source": "ISO 19650-2",
                    "type": "definition"
                }
            },

            {
                "id": "e13",
                "source": "CDE",
                "target": "WorkInProgress",
                "relationship": "contains",
                "label": "contains",
                "evidence": {
                    "quote": "The common data environment is the agreed source of information used to manage information containers.",
                    "source": "ISO 19650-1",
                    "type": "definition"
                }
            },

            {
                "id": "e14",
                "source": "CDE",
                "target": "Shared",
                "relationship": "contains",
                "label": "contains",
                "evidence": {
                    "quote": "Information containers move through states within the common data environment.",
                    "source": "ISO 19650-1",
                    "type": "definition"
                }
            },

            {
                "id": "e15",
                "source": "CDE",
                "target": "Published",
                "relationship": "contains",
                "label": "contains",
                "evidence": {
                    "quote": "Authorized information is made available through the common data environment.",
                    "source": "ISO 19650-1",
                    "type": "definition"
                }
            },

            {
                "id": "e16",
                "source": "CDE",
                "target": "Archived",
                "relationship": "contains",
                "label": "contains",
                "evidence": {
                    "quote": "The archive state preserves the history of information containers.",
                    "source": "ISO 19650-1",
                    "type": "definition"
                }
            }

        ]
    }
}