{
    "metadata": {
        "id": "iso19650-cde-workflow",
        "name": "CDE Workflow and Information Production",
        "description": "Comprehensive representation of information container states, coordination processes, exchanges, and roles within the Common Data Environment according to ISO 19650:2026 draft.",
        "type": "process-map",
        "standard": "ISO 19650",
        "version": "draft",
        "part": "Part 1 / Part 2",
        "created": "2026-03-14",
        "updated": "2026-03-17",
        "author": "ISO19650 Knowledge Maps",
        "tags": [ "CDE", "workflow", "information-state", "container", "information-production" ]
    },

    "graph": {

        "nodes": [

            {
                "id": "InformationContainer",
                "label": "Information Container",
                "type": "information",
                "description": "Named persistent set of information retrievable from within a file, system or application storage hierarchy."
            },

            {
                "id": "InformationModel",
                "label": "Information Model",
                "type": "information",
                "description": "Structured aggregation of multiple information containers forming a project information model or asset information model."
            },

            {
                "id": "InformationPurpose",
                "label": "Information Purpose",
                "type": "concept",
                "description": "Reason why information is produced and used such as coordination, approval, construction, or asset operation."
            },

            {
                "id": "InformationProductionRequirements",
                "label": "Information Production Requirements",
                "type": "information",
                "description": "Specification defining what information must be produced, when it must be delivered, and for what purpose."
            },

            {
                "id": "WorkInProgress",
                "label": "WORK IN PROGRESS",
                "type": "state",
                "description": "State where information is being developed by its authoring appointed party and is not visible or accessible to other parties."
            },

            {
                "id": "Shared",
                "label": "SHARED",
                "type": "state",
                "description": "State where information is shared with other parties for coordination and collaborative development."
            },

            {
                "id": "Submitted",
                "label": "SUBMITTED",
                "type": "state",
                "description": "State where information has been authorized by the lead appointed party and submitted to the appointing party for acceptance."
            },

            {
                "id": "Published",
                "label": "PUBLISHED",
                "type": "state",
                "description": "State where information has been accepted by the appointing party and is authorized for use."
            },

            {
                "id": "Archived",
                "label": "ARCHIVED",
                "type": "state",
                "description": "State where superseded information containers are retained for audit and historical reference."
            },

            {
                "id": "CheckReviewApprove",
                "label": "Check / Review / Approve",
                "type": "process",
                "description": "Process where the appointed party verifies information containers before sharing."
            },

            {
                "id": "CoordinationReview",
                "label": "Coordination Review",
                "type": "process",
                "description": "Process where appointed parties coordinate shared information containers to resolve issues and inconsistencies."
            },

            {
                "id": "InformationExchange",
                "label": "Information Exchange",
                "type": "process",
                "description": "Planned event where an information model is delivered to satisfy information production requirements."
            },

            {
                "id": "ReviewAuthorize",
                "label": "Review / Authorize",
                "type": "process",
                "description": "Process where the lead appointed party reviews the information model against requirements and authorizes it."
            },

            {
                "id": "ReviewAccept",
                "label": "Review / Accept",
                "type": "process",
                "description": "Process where the appointing party reviews and accepts the submitted information model."
            },

            {
                "id": "StatusCode",
                "label": "Status Code",
                "type": "information",
                "description": "Property signifying the permitted use of an information container based on its workflow state and purpose."
            },

            {
                "id": "CDE",
                "label": "Common Data Environment",
                "type": "system",
                "description": "Operational framework combining the information production workflow and enabling technologies."
            },

            {
                "id": "AppointedParty",
                "label": "Appointed Party",
                "type": "role",
                "description": "Party responsible for generating and coordinating information containers."
            },

            {
                "id": "LeadAppointedParty",
                "label": "Lead Appointed Party",
                "type": "role",
                "description": "Party responsible for coordinating information production and authorizing information models."
            },

            {
                "id": "AppointingParty",
                "label": "Appointing Party",
                "type": "role",
                "description": "Party accountable for defining information requirements and accepting information deliverables."
            }

        ],

        "edges": [

            {
                "id": "e1",
                "source": "InformationContainer",
                "target": "InformationModel",
                "relationship": "aggregated_into",
                "label": "aggregated into",
                "evidence": {
                    "quote": "Information models consist of structured collections of information containers.",
                    "source": "ISO 19650 Concept",
                    "type": "definition"
                }
            },

            {
                "id": "e2",
                "source": "InformationContainer",
                "target": "WorkInProgress",
                "relationship": "created_in",
                "label": "created in",
                "evidence": {
                    "quote": "Information containers start the information production workflow in the WORK IN PROGRESS state.",
                    "source": "ISO 19650-1 Draft",
                    "type": "definition"
                }
            },

            {
                "id": "e3",
                "source": "AppointedParty",
                "target": "WorkInProgress",
                "relationship": "develops_in",
                "label": "develops in",
                "evidence": {
                    "quote": "Information within containers is generated and amended by the appointed party while in the WORK IN PROGRESS state.",
                    "source": "ISO 19650-1 Draft",
                    "type": "definition"
                }
            },

            {
                "id": "e4",
                "source": "WorkInProgress",
                "target": "CheckReviewApprove",
                "relationship": "submitted_for",
                "label": "submitted for",
                "evidence": {
                    "quote": "Before information is shared it shall be checked, reviewed and approved.",
                    "source": "ISO 19650-1 Draft",
                    "type": "direct_quote"
                }
            },

            {
                "id": "e5",
                "source": "CheckReviewApprove",
                "target": "Shared",
                "relationship": "transitions_to",
                "label": "transitions to",
                "evidence": {
                    "quote": "Following checking and approval the information container is shared with other parties.",
                    "source": "ISO 19650-1 Draft",
                    "type": "definition"
                }
            },

            {
                "id": "e6",
                "source": "Shared",
                "target": "CoordinationReview",
                "relationship": "undergoes",
                "label": "undergoes",
                "evidence": {
                    "quote": "Shared information supports coordination between appointed parties.",
                    "source": "ISO 19650-1 Draft",
                    "type": "definition"
                }
            },

            {
                "id": "e7",
                "source": "CoordinationReview",
                "target": "WorkInProgress",
                "relationship": "returns_to",
                "label": "returns to",
                "evidence": {
                    "quote": "Information containers may be returned to work in progress if amendments are required.",
                    "source": "ISO 19650 Concept",
                    "type": "inferred_relationship"
                }
            },

            {
                "id": "e8",
                "source": "Shared",
                "target": "InformationExchange",
                "relationship": "prepared_for",
                "label": "prepared for",
                "evidence": {
                    "quote": "Information exchanges occur when information models are delivered to satisfy defined requirements.",
                    "source": "ISO 19650-2 Draft",
                    "type": "definition"
                }
            },

            {
                "id": "e9",
                "source": "InformationExchange",
                "target": "ReviewAuthorize",
                "relationship": "initiates",
                "label": "initiates",
                "evidence": {
                    "quote": "Before submitting information models to the appointing party the lead appointed party undertakes review and authorization.",
                    "source": "ISO 19650-2 Draft",
                    "type": "definition"
                }
            },

            {
                "id": "e10",
                "source": "LeadAppointedParty",
                "target": "ReviewAuthorize",
                "relationship": "performs",
                "label": "performs",
                "evidence": {
                    "quote": "The lead appointed party coordinates and authorizes the information model prior to submission.",
                    "source": "ISO 19650-2 Draft",
                    "type": "definition"
                }
            },

            {
                "id": "e11",
                "source": "ReviewAuthorize",
                "target": "Submitted",
                "relationship": "transitions_to",
                "label": "transitions to",
                "evidence": {
                    "quote": "Authorized information is submitted to the appointing party.",
                    "source": "ISO 19650 Draft",
                    "type": "definition"
                }
            },

            {
                "id": "e11a",
                "source": "Submitted",
                "target": "ReviewAccept",
                "relationship": "reviewed_by",
                "label": "reviewed by",
                "evidence": {
                    "quote": "Submitted information is reviewed and accepted by the appointing party.",
                    "source": "ISO 19650 Draft",
                    "type": "definition"
                }
            },

            {
                "id": "e12",
                "source": "AppointingParty",
                "target": "ReviewAccept",
                "relationship": "performs",
                "label": "performs",
                "evidence": {
                    "quote": "The appointing party shall undertake a review of the information model and accept the information container(s).",
                    "source": "ISO 19650-2:2026 Draft, Clause 5.8.8",
                    "type": "direct_quote"
                }
            },

            {
                "id": "e13",
                "source": "ReviewAccept",
                "target": "Published",
                "relationship": "transitions_to",
                "label": "transitions to",
                "evidence": {
                    "quote": "Accepted information containers transition to the PUBLISHED state.",
                    "source": "ISO 19650-1 Draft",
                    "type": "definition"
                }
            },

            {
                "id": "e14",
                "source": "ReviewAccept",
                "target": "Shared",
                "relationship": "returns_to_if_rejected",
                "label": "returns to",
                "evidence": {
                    "quote": "If the information model is rejected it shall be amended and resubmitted.",
                    "source": "ISO 19650-2 Draft",
                    "type": "direct_quote"
                }
            },

            {
                "id": "e15",
                "source": "Published",
                "target": "Archived",
                "relationship": "superseded_as",
