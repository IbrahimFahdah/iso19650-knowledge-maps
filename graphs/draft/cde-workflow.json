{
    "metadata": {
        "id": "iso19650-cde-workflow",
        "name": "CDE Workflow",
        "description": "Information container states within the Common Data Environment defined in ISO 19650.",
        "type": "process-map",
        "standard": "ISO 19650",
        "version": "draft",
        "part": "Part 1 / Part 2",
        "created": "2026-03-14",
        "author": "ISO19650 Knowledge Maps",
        "tags": [ "CDE", "workflow", "information-state", "draft" ]
    },

    "graph": {

        "nodes": [

            {
                "id": "InformationContainer",
                "label": "Information Container",
                "type": "information",
                "description": "A container of information managed within the Common Data Environment."
            },

            {
                "id": "WorkInProgress",
                "label": "Work In Progress",
                "type": "process",
                "description": "State where information is being developed by its authoring team."
            },

            {
                "id": "Shared",
                "label": "Shared",
                "type": "process",
                "description": "State where information is shared with other teams for coordination."
            },

            {
                "id": "Submitted",
                "label": "Submitted",
                "type": "process",
                "description": "State where information is submitted to the appointing party or parties outside the information production team."
            },

            {
                "id": "Published",
                "label": "Published",
                "type": "process",
                "description": "State where information has been authorized for use and is the most current revision."
            },

            {
                "id": "Archived",
                "label": "Archived",
                "type": "process",
                "description": "State where superseded information is retained for audit but no longer approved for use."
            },

            {
                "id": "StatusCode",
                "label": "Status Code",
                "type": "information",
                "description": "Property signifying the permitted use of an information container."
            },

            {
                "id": "CDE",
                "label": "Common Data Environment",
                "type": "system",
                "description": "Operational framework combining workflow and technologies to facilitate collaborative information production."
            }

        ],

        "edges": [

            {
                "id": "e1",
                "source": "InformationContainer",
                "target": "WorkInProgress",
                "relationship": "developed_in",
                "label": "developed in",
                "evidence": {
                    "quote": "Information containers start the information production workflow in the WORK IN PROGRESS state.",
                    "source": "ISO 19650-1:2026 Draft, Clause 11.3.2",
                    "type": "direct_quote"
                }
            },

            {
                "id": "e2",
                "source": "WorkInProgress",
                "target": "Shared",
                "relationship": "transitions_to",
                "label": "transitions to",
                "evidence": {
                    "quote": "When an information container is ready to be shared with the information production team it transitions from WORK IN PROGRESS to SHARED.",
                    "source": "ISO 19650-1:2026 Draft, Clause 11.3.3",
                    "type": "direct_quote"
                }
            },

            {
                "id": "e3",
                "source": "Shared",
                "target": "WorkInProgress",
                "relationship": "may_return_to",
                "label": "may return to",
                "evidence": {
                    "quote": "Information containers may return to work in progress following coordination feedback.",
                    "source": "ISO 19650 Draft",
                    "type": "inferred_relationship"
                }
            },

            {
                "id": "e4",
                "source": "Shared",
                "target": "Submitted",
                "relationship": "transitions_to",
                "label": "transitions to",
                "evidence": {
                    "quote": "When an information container is ready to be submitted to the appointing party it transitions from the SHARED state to the SUBMITTED state.",
                    "source": "ISO 19650-1:2026 Draft, Clause 11.3.4",
                    "type": "direct_quote"
                }
            },

            {
                "id": "e5",
                "source": "Submitted",
                "target": "Published",
                "relationship": "authorized_as",
                "label": "authorized as",
                "evidence": {
                    "quote": "Information containers that have been accepted by the appointing party transition to the PUBLISHED state.",
                    "source": "ISO 19650-1:2026 Draft, Clause 11.3.5",
                    "type": "direct_quote"
                }
            },

            {
                "id": "e6",
                "source": "Submitted",
                "target": "Shared",
                "relationship": "may_return_to",
                "label": "may return to",
                "evidence": {
                    "quote": "Information containers may return to the SHARED state following review feedback requiring amendment.",
                    "source": "ISO 19650-1:2026 Draft",
                    "type": "inferred_relationship"
                }
            },

            {
                "id": "e7",
                "source": "Published",
                "target": "Archived",
                "relationship": "retained_as",
                "label": "retained as",
                "evidence": {
                    "quote": "Information containers that are superseded transition to the ARCHIVED state.",
                    "source": "ISO 19650-1:2026 Draft, Clause 11.3.6",
                    "type": "direct_quote"
                }
            },

            {
                "id": "e8",
                "source": "InformationContainer",
                "target": "StatusCode",
                "relationship": "assigned",
                "label": "assigned",
                "evidence": {
                    "quote": "Each revision of an information container is assigned a status reflecting its permitted use.",
                    "source": "ISO 19650-1:2026 Draft, Clause 11.3.1",
                    "type": "direct_quote"
                }
            },

            {
                "id": "e9",
                "source": "CDE",
                "target": "InformationContainer",
                "relationship": "contains",
                "label": "contains",
                "evidence": {
                    "quote": "All information production is undertaken via the common data environment.",
                    "source": "ISO 19650-1:2026 Draft",
                    "type": "direct_quote"
                }
            },

            {
                "id": "e10",
                "source": "CDE",
                "target": "WorkInProgress",
                "relationship": "contains",
                "label": "contains",
                "evidence": {
                    "quote": "The information production workflow includes the WORK IN PROGRESS state.",
                    "source": "ISO 19650-1:2026 Draft, Clause 11.3.1",
                    "type": "definition"
                }
            },

            {
                "id": "e11",
                "source": "CDE",
                "target": "Shared",
                "relationship": "contains",
                "label": "contains",
                "evidence": {
                    "quote": "The information production workflow includes the SHARED state.",
                    "source": "ISO 19650-1:2026 Draft, Clause 11.3.1",
                    "type": "definition"
                }
            },

            {
                "id": "e12",
                "source": "CDE",
                "target": "Submitted",
                "relationship": "contains",
                "label": "contains",
                "evidence": {
                    "quote": "The information production workflow includes the SUBMITTED state.",
                    "source": "ISO 19650-1:2026 Draft, Clause 11.3.1",
                    "type": "definition"
                }
            },

            {
                "id": "e13",
                "source": "CDE",
                "target": "Published",
                "relationship": "contains",
                "label": "contains",
                "evidence": {
                    "quote": "The information production workflow includes the PUBLISHED state.",
                    "source": "ISO 19650-1:2026 Draft, Clause 11.3.1",
                    "type": "definition"
                }
            },

            {
                "id": "e14",
                "source": "CDE",
                "target": "Archived",
                "relationship": "contains",
                "label": "contains",
                "evidence": {
                    "quote": "The information production workflow includes the ARCHIVED state.",
                    "source": "ISO 19650-1:2026 Draft, Clause 11.3.1",
                    "type": "definition"
                }
            }

        ]
    }
}