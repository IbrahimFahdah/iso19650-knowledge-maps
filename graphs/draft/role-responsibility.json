        "name": "Role Responsibility Map",
        "description": "Roles and responsibilities in the ISO 19650 draft, emphasizing information production teams and lifecycle information management.",
        "type": "role-map",
        "standard": "ISO 19650",
        "version": "draft",
        "part": "Part 1 / Part 2",
