        "tags": [ "roles", "responsibilities", "information-production", "draft" ]
    },

    "graph": {

        "nodes": [

            {
                "id": "AppointingParty",
                "label": "Appointing Party",
                "type": "role",
                "description": "Organization responsible for defining information purposes and requirements, and appointing lead appointed parties."
            },

            {
                "id": "LeadAppointedParty",
                "label": "Lead Appointed Party",
                "type": "role",
                "description": "Organization responsible for managing information production and coordinating appointed parties."
            },

            {
                "id": "AppointedParty",
                "label": "Appointed Party",
                "type": "role",
                "description": "Organization responsible for generating information and approving information containers."
            },

            {
                "id": "InformationProductionTeam",
                "label": "Information Production Team",
                "type": "role",
                "description": "Team responsible for producing information, comprising lead appointed party and appointed parties. (DEPRECATED: delivery team)"
            },

            {
                "id": "InformationManager",
                "label": "Information Manager",
                "type": "role",
                "description": "Role responsible for implementing and overseeing the information management process."
            },

            {
                "id": "InformationUser",
                "label": "Information User",
                "type": "role",
                "description": "Stakeholder using information to support lifecycle decisions."
            },

            {
                "id": "InformationPurpose",
                "label": "Information Purpose",
                "type": "concept",
                "description": "Reason why information is required to support decision-making."
            },

            {
                "id": "InformationRequirement",
                "label": "Information Requirement",
                "type": "information",
                "description": "Specification of information required to fulfill an information purpose."
            },

            {
                "id": "InformationProductionRequirements",
                "label": "Information Production Requirements",
                "type": "information",
                "description": "Information requirements relating to an appointment. (DEPRECATED: Exchange Information Requirements)"
            },

            {
                "id": "InformationManagementProcess",
                "label": "Information Management Process",
                "type": "process",
                "description": "Process governing how information is specified, produced, verified and exchanged."
            },

            {
                "id": "InformationProduction",
                "label": "Information Production",
                "type": "process",
                "description": "Activity of creating information to satisfy information requirements."
            },

            {
                "id": "InformationChecking",
                "label": "Information Checking",
                "type": "process",
                "description": "Quality assurance check of information containers against the information production standard."
            },

            {
                "id": "InformationReviewAndApprove",
                "label": "Review and Approve (Container)",
                "type": "process",
                "description": "Technical review of information container by appointed party and approval for a specified use."
            },

            {
                "id": "InformationReviewAndAuthorize",
                "label": "Review and Authorize (Model)",
                "type": "process",
                "description": "Review of information model by lead appointed party and authorization of its approved use."
            },

            {
                "id": "InformationReviewAndAccept",
                "label": "Review and Accept (Model)",
                "type": "process",
                "description": "Review of information model by appointing party and acceptance of its approved use."
            },

            {
                "id": "InformationExchange",
                "label": "Information Exchange",
                "type": "process",
                "description": "Transfer of verified information between stakeholders."
            },

            {
                "id": "CDE",
                "label": "Common Data Environment",
                "type": "system",
                "description": "Shared environment used to manage and exchange information."
            }

        ],

