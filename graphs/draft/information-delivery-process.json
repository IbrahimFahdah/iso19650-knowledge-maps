{
    "metadata": {
        "id": "iso19650-information-delivery-process",
        "name": "Information Delivery Process",
        "description": "Lifecycle-oriented information delivery workflow in the ISO 19650 draft, emphasizing information purposes, requirements, production planning, and exchange to support decisions.",
        "type": "process-map",
        "standard": "ISO 19650",
        "version": "draft",
        "part": "Part 1 / Part 2",
        "created": "2026-03-14",
        "author": "ISO19650 Knowledge Maps",
        "tags": [ "process", "lifecycle", "information-management", "draft" ]
    },

    "graph": {

        "nodes": [

            {
                "id": "Decision",
                "label": "Lifecycle Decision",
                "type": "concept",
                "description": "Decision taken during the lifecycle of an asset which requires supporting information."
            },

            {
                "id": "InformationPurpose",
                "label": "Information Purpose",
                "type": "concept",
                "description": "Reason why information is required to support a lifecycle decision."
            },

            {
                "id": "InformationRequirement",
                "label": "Information Requirement",
                "type": "information",
                "description": "Specification of information needed to fulfill an information purpose."
            },

            {
                "id": "InformationProductionRequirements",
                "label": "Information Production Requirements",
                "type": "information",
                "description": "Information requirements relating to an appointment. (DEPRECATED: Exchange Information Requirements)"
            },

            {
                "id": "InformationProductionPlanning",
                "label": "Information Production Planning",
                "type": "process",
                "description": "Planning how information will be produced by information production teams."
            },

            {
                "id": "InformationProductionPlan",
                "label": "Information Production Plan",
                "type": "information",
                "description": "Document explaining the overall approach that an information production team will take. (DEPRECATED: BIM Execution Plan)"
            },

            {
                "id": "InformationProductionSchedule",
                "label": "Information Production Schedule",
                "type": "information",
                "description": "Details of information containers to be produced during an appointment. (DEPRECATED: task information delivery plan, master information delivery plan)"
            },

            {
                "id": "InformationProduction",
                "label": "Information Production",
                "type": "process",
                "description": "Creation and coordination of information to meet defined requirements, including generation, checking, review, approval, authorization and acceptance."
            },

            {
                "id": "InformationChecking",
                "label": "Information Checking",
                "type": "process",
                "description": "Quality assurance check of information containers against the information production standard."
            },

            {
                "id": "InformationReviewAndApprove",
                "label": "Review and Approve",
                "type": "process",
                "description": "Technical review of information container by appointed party and approval for a specified use."
            },

            {
                "id": "InformationReviewAndAuthorize",
                "label": "Review and Authorize",
                "type": "process",
                "description": "Review of information model by lead appointed party and authorization of its approved use."
            },

            {
                "id": "InformationReviewAndAccept",
                "label": "Review and Accept",
                "type": "process",
                "description": "Review of information model by appointing party and acceptance of its approved use."
            },

            {
                "id": "InformationExchange",
                "label": "Information Exchange",
                "type": "process",
                "description": "Transfer of verified information between stakeholders."
            },

            {
                "id": "InformationContainer",
                "label": "Information Container",
                "type": "information",
                "description": "Unit of information delivered and managed within the common data environment."
            },

            {
                "id": "InformationModel",
                "label": "Information Model",
                "type": "information",
                "description": "Structured collection of information containers used to support decisions."
            },

            {
                "id": "CDE",
                "label": "Common Data Environment",
                "type": "system",
                "description": "Shared information environment used to manage and exchange information."
            },

            {
                "id": "InformationProductionMilestone",
                "label": "Information Production Milestone",
                "type": "process",
                "description": "Defined milestone where information must be delivered. (DEPRECATED: information delivery milestone)"
            }

        ],

        "edges": [

            {
                "id": "e1",
                "source": "Decision",
                "target": "InformationPurpose",
                "relationship": "drives",
                "label": "drives",
                "evidence": {
                    "quote": "Information is required to support decision-making during the lifecycle of assets.",
                    "source": "ISO 19650 Draft",
                    "type": "direct_quote"
                }
            },

            {
                "id": "e2",
                "source": "InformationPurpose",
                "target": "InformationRequirement",
                "relationship": "defines",
                "label": "defines",
                "evidence": {
                    "quote": "Information is only specified and produced in response to one or more clear information purposes.",
                    "source": "ISO 19650 Draft",
                    "type": "direct_quote"
                }
            },

            {
                "id": "e3",
                "source": "InformationRequirement",
                "target": "InformationProductionRequirements",
                "relationship": "refines",
                "label": "refines",
                "evidence": {
                    "quote": "Information production requirements are defined by the appointing party and can also be defined by a lead appointed party.",
                    "source": "ISO 19650-1:2026 Draft, Clause 7.2.4",
                    "type": "direct_quote"
                }
            },

            {
                "id": "e4",
                "source": "InformationProductionRequirements",
                "target": "InformationProductionPlanning",
                "relationship": "drives",
                "label": "drives",
                "evidence": {
                    "quote": "Planning for information production is the responsibility of each lead appointed party and their appointed parties.",
                    "source": "ISO 19650-1:2026 Draft, Clause 9.1",
                    "type": "direct_quote"
                }
            },

            {
                "id": "e5",
                "source": "InformationProductionPlanning",
                "target": "InformationProductionPlan",
                "relationship": "produces",
                "label": "produces",
                "evidence": {
                    "quote": "An information production plan explains the overall approach that an information production team will take.",
                    "source": "ISO 19650-1:2026 Draft, Clause 9.1",
                    "type": "direct_quote"
                }
            },

            {
                "id": "e6",
                "source": "InformationProductionPlanning",
                "target": "InformationProductionSchedule",
                "relationship": "produces",
                "label": "produces",
                "evidence": {
                    "quote": "An information production schedule shows detailed timings of production of information containers.",
                    "source": "ISO 19650-1:2026 Draft, Clause 9.1",
                    "type": "direct_quote"
                }
            },

            {
                "id": "e7",
                "source": "InformationProductionPlanning",
                "target": "InformationProduction",
                "relationship": "enables",
                "label": "enables",
                "evidence": {
                    "quote": "Information production is planned and carried out by each information production team.",
                    "source": "ISO 19650 Draft",
                    "type": "direct_quote"
                }
            },

            {
                "id": "e8",
                "source": "InformationProduction",
                "target": "InformationContainer",
                "relationship": "produces",
                "label": "produces",
                "evidence": {
                    "quote": "Information production includes generation and aggregation of information containers.",
                    "source": "ISO 19650-1:2026 Draft, Clause 3.2.10",
                    "type": "inferred_relationship"
                }
            },

            {
                "id": "e9",
                "source": "InformationProduction",
                "target": "InformationChecking",
                "relationship": "includes",
                "label": "includes",
                "evidence": {
                    "quote": "Information production includes generation, coordination, checking, reviewing, approval, authorization, acceptance and aggregation.",
                    "source": "ISO 19650-1:2026 Draft, Clause 3.2.10",
                    "type": "direct_quote"
                }
            },

            {
                "id": "e10",
                "source": "InformationChecking",
                "target": "InformationReviewAndApprove",
                "relationship": "followed_by",
                "label": "followed by",
                "evidence": {
                    "quote": "Each appointed party shall undertake a quality assurance check and then review and approve the information container.",
                    "source": "ISO 19650-2:2026 Draft",
                    "type": "inferred_relationship"
                }
            },

            {
                "id": "e11",
                "source": "InformationReviewAndApprove",
                "target": "InformationReviewAndAuthorize",
                "relationship": "followed_by",
                "label": "followed by",
                "evidence": {
                    "quote": "The lead appointed party shall review and authorize the information model.",
                    "source": "ISO 19650-2:2026 Draft",
                    "type": "direct_quote"
                }
            },

            {
                "id": "e12",
                "source": "InformationReviewAndAuthorize",
                "target": "InformationReviewAndAccept",
                "relationship": "followed_by",
                "label": "followed by",
                "evidence": {
                    "quote": "The appointing party shall review the information model and accept the information container(s).",
                    "source": "ISO 19650-2:2026 Draft",
                    "type": "direct_quote"
                }
            },

            {
                "id": "e13",
                "source": "InformationReviewAndAccept",
                "target": "InformationExchange",
                "relationship": "enables",
                "label": "enables",
                "evidence": {
                    "quote": "Once accepted, the appointing party aggregates the information models.",
                    "source": "ISO 19650-2",
                    "type": "inferred_relationship"
                }
            },

            {
                "id": "e14",
                "source": "InformationExchange",
                "target": "InformationContainer",
                "relationship": "delivers",
                "label": "delivers",
                "evidence": {
                    "quote": "Information exchanges deliver verified information containers between parties.",
                    "source": "ISO 19650-2",
                    "type": "definition"
                }
            },

            {
                "id": "e15",
                "source": "InformationContainer",
                "target": "InformationModel",
                "relationship": "forms",
                "label": "forms",
                "evidence": {
                    "quote": "Information models are collections of information containers.",
                    "source": "ISO 19650-1",
                    "type": "definition"
                }
            },

            {
                "id": "e16",
                "source": "InformationModel",
                "target": "Decision",
                "relationship": "supports",
                "label": "supports",
                "evidence": {
                    "quote": "Information models support decision-making throughout the lifecycle of assets.",
                    "source": "ISO 19650-1",
                    "type": "definition"
                }
            },

            {
                "id": "e17",
                "source": "CDE",
                "target": "InformationContainer",
                "relationship": "contains",
                "label": "contains",
                "evidence": {
                    "quote": "The common data environment is the agreed source of information containers.",
                    "source": "ISO 19650-1",
                    "type": "definition"
                }
            },

            {
                "id": "e18",
                "source": "CDE",
                "target": "InformationProduction",
                "relationship": "supports",
                "label": "supports",
                "evidence": {
                    "quote": "All information production is undertaken via the common data environment.",
                    "source": "ISO 19650-1",
                    "type": "direct_quote"
                }
            },

            {
                "id": "e19",
                "source": "CDE",
                "target": "InformationExchange",
                "relationship": "supports",
                "label": "supports",
                "evidence": {
                    "quote": "The common data environment facilitates collaborative production and exchange of information.",
                    "source": "ISO 19650-1",
                    "type": "inferred_relationship"
                }
            },

            {
                "id": "e20",
                "source": "InformationProductionMilestone",
                "target": "InformationProductionSchedule",
                "relationship": "drives",
                "label": "drives",
                "evidence": {
                    "quote": "Information production milestones define the events or dates when information is required.",
                    "source": "ISO 19650-1:2026 Draft, Clause 7.2.3",
                    "type": "direct_quote"
                }
            },

            {
                "id": "e21",
                "source": "InformationProductionRequirements",
                "target": "InformationProductionMilestone",
                "relationship": "establishes",
                "label": "establishes",
                "evidence": {
                    "quote": "The appointing party shall establish the information production milestones.",
                    "source": "ISO 19650-2:2026 Draft, Clause 5.4.1",
                    "type": "direct_quote"
                }
            }

        ]
    }
}