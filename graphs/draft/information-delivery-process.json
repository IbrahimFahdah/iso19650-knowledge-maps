                "label": "Information Model",
                "type": "information",
                "description": "Structured collection of information containers used to support decisions."
            },

            {
                "id": "CDE",
                "label": "Common Data Environment",
                "type": "system",
                "description": "Shared information environment used to manage and exchange information."
            }

