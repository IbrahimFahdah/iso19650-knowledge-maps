                "relationship": "drives",
                "label": "drives",
                "evidence": {
                    "quote": "Information is required to support decision-making during the lifecycle of assets.",
                    "source": "ISO 19650 Draft",
                    "type": "direct_quote"
                }
            },

            {
                "id": "e2",
                "source": "InformationPurpose",
                "target": "InformationRequirement",
                "relationship": "defines",
                "label": "defines",
                "evidence": {
                    "quote": "Information is only specified and produced in response to one or more clear information purposes.",
                    "source": "ISO 19650 Draft",
                    "type": "direct_quote"
                }
            },

